# WAYFARE backend — API credentials
# Copy this file to `.env` and replace the placeholders with your real keys.

# RapidAPI key, shared by the flight (Sky Scrapper) and hotel (Booking.com)
# MCP servers under mcp_servers/. Read by sky_scrapper.py and booking_com.py.
# https://rapidapi.com/apiheya/api/sky-scrapper
RAPIDAPI_KEY=your_rapidapi_key_here

# Google Generative AI (Gemini) key for the researcher node's
# ChatGoogleGenerativeAI model in graph.py.
# https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=your_google_api_key_here

# Gemini key for Dhruv's curator agent (services/gemini_service.py).
# Typically the same value as GOOGLE_API_KEY above.
GEMINI_API_KEY=your_gemini_api_key_here
