# WAYFARE frontend — build-time configuration
# Copy this file to `.env` and adjust if your backend is not on the default port.
# Vite only exposes variables prefixed with `VITE_` to client code.

# Base URL of the FastAPI backend (backend/main.py). Read by src/services/api.ts.
# Defaults to http://localhost:8000 when unset.
VITE_API_BASE_URL=http://localhost:8000
